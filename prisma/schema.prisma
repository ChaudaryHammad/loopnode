datasource db {
  provider  = "postgresql"
  
}


generator client {
  provider = "prisma-client-js"
}

// ─── ENUMS ────────────────────────────────────────
enum Role {
  ADMIN
  USER
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ScanFrequency {
  MANUAL
  DAILY
  WEEKLY
  MONTHLY
}

enum IssueSeverity {
  CRITICAL
  MAJOR
  MINOR
  INFO
}

enum IssueCategory {
  PERFORMANCE
  ACCESSIBILITY
  SEO
  SECURITY
  BROKEN_LINKS
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum BrokenLinkScanMode {
  INTERNAL
  EXTERNAL
}

enum BrokenLinkScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ReportType {
  FULL_AUDIT
  EXECUTIVE_SUMMARY
  ISSUES_CSV
  PERFORMANCE_REPORT
  SEO_REPORT
  SECURITY_REPORT
  ACCESSIBILITY_REPORT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PlanTier {
  STARTER
  PRO
  AGENCY
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}

enum UpgradeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ManualPaymentMethod {
  PAYONEER
  BANK_TRANSFER
  EASYPAISA
  JAZZCASH
  OTHER
}

enum NotificationType {
  UPGRADE_SUBMITTED
  UPGRADE_APPROVED
  UPGRADE_REJECTED
  LIMITS_INCREASED
  GENERAL
}

// ─── USER & AUTH ──────────────────────────────────
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  hashedPassword  String?
  image           String?
  role            Role      @default(USER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // Soft delete

  signupIp          String?
  signupCountry     String?
  signupCity        String?
  signupLat         Float?
  signupLng         Float?
  lastLoginIp       String?
  lastLoginCountry  String?
  lastLoginCity     String?
  lastLoginLat      Float?
  lastLoginLng      Float?
  lastLoginAt       DateTime?

  websites        Website[]
  accounts        Account[]
  sessions        Session[]
  activityLogs    ActivityLog[]
  subscription    Subscription?
  upgradeRequests UpgradeRequest[]
  notifications   Notification[]
  domainSlots     WebsiteDomainSlot[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_verification_tokens")
}

// ─── WEBSITE & SCANNING ──────────────────────────
model Website {
  id            String        @id @default(cuid())
  name          String
  url           String
  scanFrequency ScanFrequency @default(MANUAL)
  scanTimezone     String    @default("UTC")
  scanTimeOfDay    String    @default("09:00")
  scanDayOfWeek    Int?
  scanDayOfMonth   Int?
  nextScanAt       DateTime?
  lastScheduledAt  DateTime?
  /// Trigger.dev run id for the delayed `dispatch-scheduled-scan` task.
  pendingScanRunId String?
  userId        String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?     // Soft delete

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans            Scan[]
  reports          Report[]
  brokenLinkScans  BrokenLinkScan[]
  domainSlots      WebsiteDomainSlot[]

  @@index([userId])
  @@index([deletedAt])
  @@index([nextScanAt])
  @@map("websites")
}

model Scan {
  id        String     @id @default(cuid())
  websiteId String
  status    ScanStatus @default(PENDING)

  // Scores (0-100)
  overallScore       Float?
  performanceScore   Float?
  accessibilityScore Float?
  seoScore           Float?
  securityScore      Float?

  // Performance metrics
  fcp     Float?  // First Contentful Paint (ms)
  lcp     Float?  // Largest Contentful Paint (ms)
  cls     Float?  // Cumulative Layout Shift
  inp     Float?  // Interaction to Next Paint (ms)
  tbt     Float?  // Total Blocking Time (ms)

  // Live audit progress
  phase           String?
  statusMessage   String? @db.Text
  progressPercent Float   @default(0)
  triggerRunId    String?

  // Metadata
  screenshot   String?   // Cloudinary URL
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@index([websiteId])
  @@index([status])
  @@index([createdAt])
  @@map("scans")
}

model Issue {
  id             String        @id @default(cuid())
  scanId         String
  category       IssueCategory
  severity       IssueSeverity
  status         IssueStatus   @default(OPEN)
  fingerprint    String        @default("")
  title          String
  description    String        @db.Text
  selector       String?       // CSS selector (for accessibility issues)
  url            String?       // Affected URL (for broken links)
  recommendation String?       @db.Text
  metadata       Json?         // Flexible per-category data
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([fingerprint])
  @@map("issues")
}

// ─── BROKEN LINK SCANS (separate from audit scans) ─
model BrokenLinkScan {
  id              String               @id @default(cuid())
  websiteId       String
  status          BrokenLinkScanStatus @default(PENDING)
  mode            BrokenLinkScanMode
  phase           String?
  statusMessage   String?              @db.Text
  pagesDiscovered Int                  @default(0)
  pagesCrawled    Int                  @default(0)
  linksFound      Int                  @default(0)
  linksChecked    Int                  @default(0)
  brokenCount     Int                  @default(0)
  progressPercent Float                @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?              @db.Text
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  website Website            @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  results BrokenLinkResult[]

  @@index([websiteId])
  @@index([status])
  @@index([createdAt])
  @@map("broken_link_scans")
}

model BrokenLinkResult {
  id            String        @id @default(cuid())
  scanId        String
  href          String        @db.Text
  sourcePageUrl String        @db.Text
  statusCode    Int?
  errorMessage  String?
  elementTag    String?
  elementId     String?
  elementClass  String?
  elementText   String?
  selector      String?
  attribute     String?
  severity      IssueSeverity @default(MAJOR)
  createdAt     DateTime      @default(now())

  scan BrokenLinkScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@map("broken_link_results")
}

// ─── REPORTS ─────────────────────────────────────
model Report {
  id                 String     @id @default(cuid())
  websiteId          String
  scanId             String?
  type               ReportType @default(FULL_AUDIT)
  format             String     @default("pdf")
  title              String
  fileUrl            String
  cloudinaryPublicId String?
  fileSize           Int?
  preparedFor        String?
  brandName          String?
  shareToken         String?    @unique
  shareEnabled       Boolean    @default(false)
  scanCompletedAt    DateTime?
  createdAt          DateTime   @default(now())

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([type])
  @@index([createdAt])
  @@index([shareToken])
  @@map("reports")
}

// ─── NEWSLETTER ──────────────────────────────────
model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([email])
  @@map("newsletter_subscribers")
}

// ─── SUBSCRIPTIONS (billing — Stripe webhooks pending) ─
model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 PlanTier?
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  websiteLimitOverride Int?
  adminNotes           String?            @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

// ─── CONTACT INBOX ───────────────────────────────
model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String               @db.Text
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
  readAt    DateTime?

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ─── ACTIVITY LOG ────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   // e.g. "WEBSITE_CREATED", "SCAN_STARTED"
  description String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

enum PaymentMethodDisplayStyle {
  CARD
  PLAIN
}

// ─── MANUAL UPGRADES & NOTIFICATIONS ─────────────

/// Admin-configured payment options shown on the upgrade page.
model PaymentMethodConfig {
  id           String                    @id @default(cuid())
  label        String
  tagline      String?
  displayStyle PaymentMethodDisplayStyle @default(PLAIN)
  /// Array of { key, value } rows shown to users (e.g. account name, IBAN).
  details      Json                      @default("[]")
  enabled      Boolean                   @default(true)
  sortOrder    Int                       @default(0)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  upgradeRequests UpgradeRequest[]

  @@index([enabled, sortOrder])
  @@map("payment_method_configs")
}

model UpgradeRequest {
  id                    String               @id @default(cuid())
  userId                String
  requestedPlan         PlanTier
  paymentMethod         ManualPaymentMethod  @default(OTHER)
  paymentMethodConfigId String?
  paymentMethodLabel    String?
  paymentReference      String
  paymentProofUrl       String?
  userNote              String?              @db.Text
  status                UpgradeRequestStatus @default(PENDING)
  adminNote             String?              @db.Text
  reviewedById          String?
  reviewedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethodConfig PaymentMethodConfig? @relation(fields: [paymentMethodConfigId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("upgrade_requests")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  href      String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

/// Tracks unique hostnames ever connected per user (slot policy + reconnect limits).
model WebsiteDomainSlot {
  id               String    @id @default(cuid())
  userId           String
  websiteId        String?
  normalizedHost   String
  consumedAt       DateTime  @default(now())
  releasedAt       DateTime?
  /// How many times this hostname has been connected (initial add counts as 1).
  lifetimeAddCount Int       @default(1)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  website Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)

  @@unique([userId, normalizedHost])
  @@index([userId])
  @@index([releasedAt])
  @@map("website_domain_slots")
}
